{
  "expo": {
    "name": "uninest_mobile",
    "slug": "uninest_mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.jpg",
    "scheme": "uninestmobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/logo.jpg",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "UniNest cần truy cập thư viện ảnh để bạn upload hình phòng trọ.",
        "NSCameraUsageDescription": "UniNest cần truy cập camera để bạn chụp ảnh phòng trọ."
      }
    },
    "android": {
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/logo.jpg"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo.jpg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "UniNest cần truy cập thư viện ảnh để bạn upload hình phòng trọ.",
          "cameraPermission": "UniNest cần truy cập camera để bạn chụp ảnh phòng trọ."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/logo.jpg",
          "imageWidth": 120,
          "android": {
            "image": "./assets/images/logo.jpg",
            "imageWidth": 120
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
